<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educare.edu.cnhtml.service.impl.CnhtmlMapper">
	
	<sql id="boardWhere">
		<if test="state > 0">
			and a.state = #{state}
		</if>
		<if test="srchCnhtType != null and srchCnhtType != ''" >
			and a.cnht_type = #{srchCnhtType}
		</if>
		<if test="srchWrd != '' and srchWrd != null">
			and (
				a.content like concat('%',#{srchWrd},'%') 
			)	
		</if>
		
	</sql>
	<select id="selectCnhtmlPageCnt" resultType="int">
		select count(*) from t_content_html where 1=1
		<include refid="boardWhere" />
	</select>
	<select id="selectCnhtmlPageList" resultMap="common.result.map.cnhtmlVO">
		select a.* 
		,(select user_nm from t_user_info where user_id = a.reg_id) reg_nm
		from t_content_html a where 1=1
		<include refid="boardWhere" />
		order by a.cnht_seq desc
		<if test="row > 0">
			LIMIT #{firstIndex}, #{row}
		</if>
	</select>
	
</mapper>