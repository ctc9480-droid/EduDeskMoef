<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educare.edu.comn.mapper.UserLangMapper">
	
	<resultMap id="map" type="com.educare.edu.comn.model.UserLang" >
		<result property="userId" column="USER_ID"/>
		
		<result property="langSeq" column="LANG_SEQ"/>
		<result property="langNm" column="LANG_NM"/>
		<result property="testNm" column="TEST_NM"/>
		<result property="mark" column="MARK"/>
		<result property="testDt" column="TEST_DT"/>
		
		<result property="updId" column="upd_id"/>
		<result property="updDe" column="upd_de"/>
	</resultMap>
	<select id="selectByPk" resultMap="map">
		SELECT * FROM t_user_lang 
		WHERE USER_ID=#{userId} AND LANG_SEQ = #{langSeq} 
	</select>
	<select id="selectByUserId" resultMap="map">
		SELECT * FROM t_user_lang 
		WHERE USER_ID=#{userId}
		order by lang_seq
	</select>
	<delete id="deleteByUserId">
		delete from t_user_lang where user_id = #{userId}
	</delete>
	<update id="updateByPk">
		UPDATE t_user_lang
		SET UPD_ID=#{updId} ,UPD_DE=#{updDe}
		<if test="langNm != null"> 	,LANG_NM 	= #{langNm} </if>
		<if test="testNm != null"> 	,TEST_NM 	= #{testNm} </if>
		<if test="mark != null">	,MARK 		= #{mark} </if>
		<if test="testDt != null">	,TEST_DT 	= #{testDt} </if>
		WHERE USER_ID=#{userId} AND LANG_SEQ = #{langSeq} 
	</update>
	<insert id="insertByPk">
		INSERT t_user_lang (
			USER_ID			,LANG_SEQ		
			,LANG_NM		,TEST_NM	,MARK		,TEST_DT	
			,UPD_ID			,UPD_DE
		) VALUES (
			#{userId}		,#{langSeq}		
			,#{langNm}		,#{testNm}	,#{mark}	,#{testDt}
			,#{updId}		,#{updDe}
		)
	</insert>
</mapper>