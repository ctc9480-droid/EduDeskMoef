<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educare.edu.comn.mapper.LectureMovTimeMapper">
	<resultMap id="map" type="com.educare.edu.comn.model.LectureMovTime">
		<result property="idx" column="IDX"/>
		<result property="mvIdx" column="MV_IDX"/>
		<result property="title" column="TITLE"/>
		<result property="url" column="URL"/>
		<result property="mvTime" column="MV_TIME"/>
		<result property="type" column="TYPE"/>
	</resultMap>
	
	<insert id="insertByPk" useGeneratedKeys="true" keyProperty="idx">
	/* com.educare.edu.comn.mapper.LectureMovTimeMapper.insertByPk */
		INSERT INTO t_lecture_mov_time
		(TITLE,MV_IDX,TITLE,URL,MV_TIME,TYPE)
		VALUES
		(#{title},#{mvIdx},#{title},#{url},#{mvTime},#{type})
	</insert>
	
	<select id="selectByMv" resultMap="map">
	/* com.educare.edu.comn.mapper.LectureMovTimeMapper.selectByMv */
		select * from t_lecture_mov_time where mv_idx=#{mvIdx} 
		<if test="type != null and type != ''">
		and type = #{type}
		</if>
		order by cast(mv_time as decimal(12,1))
	</select>
</mapper>