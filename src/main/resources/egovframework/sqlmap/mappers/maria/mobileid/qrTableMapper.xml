<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="qrTableMapper">
  	<resultMap type="com.educare.edu.mobileid.model.QrTable" id="QrTableResult">
		<id property="qrKey" column="qr_key" />
		<result property="step" column="step" />
		<result property="nonce" column="nonce" />
		<result property="vcJson" column="vc_json" />
		<result property="expireDate" column="expire_date" />
	</resultMap>

	<select id="selectQrTableByNonce" parameterType="string" resultMap="QrTableResult">
		select * from qr_table where nonce=#{nonce}
	</select>
	
	<select id="selectQrTableAllOrderByQrKeyDesc" parameterType="string" resultMap="QrTableResult">
		select * from qr_table order by qr_key desc
	</select>
	
	<insert id="insertQrTable" parameterType="QrTable" useGeneratedKeys="true" keyProperty="qrKey">
		insert into qr_table (expire_date, nonce, step)
		values (#{expireDate}, #{nonce}, #{step})
	</insert>
	
	<update id="updateQrTable" parameterType="QrTable">
		update qr_table
		set step=#{step}, vc_json=#{vcJson}
		where qr_key=#{qrKey} 
	</update>
</mapper>