<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educare.edu.comn.mapper.UserCompMapper">
	
	<resultMap id="map" type="com.educare.edu.comn.model.UserComp" >
		<result property="userId" column="USER_ID"/>
		<result property="compNm" column="comp_nm"/>
		<result property="ceoNm" column="ceo_nm"/>
		<result property="addr" column="addr"/>
		<result property="addrDtl" column="addr_dtl"/>
		<result property="postNo" column="post_no"/>
		<result property="tel" column="tel"/>
		<result property="bsnLcnsNo" column="bsn_lcns_no"/>
		<result property="bsnLcnsOrg" column="bsn_lcns_org"/>
		<result property="bsnLcnsRnm" column="bsn_lcns_rnm"/>
		<result property="bsnBankOrg" column="bsn_bank_org"/>
		<result property="bsnBankRnm" column="bsn_bank_rnm"/>
		<result property="employYn" column="employ_yn"/>
		<result property="employNum" column="employ_num"/>
		<result property="deptNm" column="DEPT_NM"/>
		<result property="posiNm" column="POSI_NM"/>
		
		<result property="updId" column="upd_id"/>
		<result property="updDe" column="upd_de"/>
	</resultMap>
	<select id="selectByPk" resultMap="map">
		select * from t_user_comp where user_id=#{userId}
	</select>
	<update id="updateByPk">
		update t_user_comp
		set upd_id=#{updId} ,upd_de=#{updDe}
		<if test="compNm != null"> 		,comp_nm 		= #{compNm} </if>
		<if test="ceoNm != null"> 		,ceo_nm 		= #{ceoNm} </if>
		<if test="addr != null"> 		,addr 			= #{addr} </if>
		<if test="addrDtl != null">		,addr_dtl 		= #{addrDtl} </if>
		<if test="postNo != null"> 		,post_no 		= #{postNo} </if>
		<if test="tel != null"> 		,tel 			= #{tel} </if>
		<if test="bsnLcnsNo != null"> 	,bsn_lcns_no 	= #{bsnLcnsNo} </if>
		<if test="bsnLcnsOrg != null"> 	,bsn_lcns_org 	= #{bsnLcnsOrg} </if>
		<if test="bsnLcnsRnm != null"> 	,bsn_lcns_rnm 	= #{bsnLcnsRnm} </if>
		<if test="bsnBankOrg != null"> 	,bsn_bank_org 	= #{bsnBankOrg} </if>
		<if test="bsnBankRnm != null"> 	,bsn_bank_rnm 	= #{bsnBankRnm} </if>
		<if test="employYn != null"> 	,employ_yn 		= #{employYn} </if>
		<if test="employNum != null"> 	,employ_num 	= #{employNum} </if>
		<if test="deptNm != null"> 		,DEPT_NM 	= #{deptNm} </if>
		<if test="posiNm != null"> 		,POSI_NM 	= #{posiNm} </if>
		where user_id=#{userId}
	</update>
	<insert id="insertByPk">
		insert t_user_comp (
			user_id			,comp_nm		,ceo_nm			,addr			,addr_dtl		,post_no	,tel
			,bsn_lcns_no	,bsn_lcns_org	,bsn_lcns_rnm   ,employ_yn 		,employ_num		,dept_nm	,posi_nm
			,upd_id			,upd_de
		) values (
			#{userId}		,#{compNm}		,#{ceoNm}		,#{addr}		,#{addrDtl}		,#{postNo}	,#{tel}
			,#{bsnLcnsNo}	,#{bsnLcnsOrg}	,#{bsnLcnsRnm}	,#{employYn}	,#{employNum}	,#{deptNm}	,#{posiNm}
			,#{updId}		,#{updDe}
		)
	</insert>
</mapper>