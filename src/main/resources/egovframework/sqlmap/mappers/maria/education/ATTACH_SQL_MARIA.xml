<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educare.edu.education.service.impl.AttachMapper">

	<resultMap id="lectureAttachMap" type="LectureAttach">
		<result property="fileSeq" column="FILE_SEQ"/>
		<result property="eduSeq" column="EDU_SEQ"/>
		<result property="fileOrg" column="FILE_ORG"/>
		<result property="fileRename" column="FILE_RENAME"/>
		<result property="fileType" column="FILE_TYPE"/>
		<result property="fileSize" column="FILE_SIZE"/>
		<result property="fileSection" column="FILE_SECTION"/>
	</resultMap>

	<insert id="inertAttach" parameterType="LectureAttach">
		INSERT INTO 
			t_lecture_attach(
				FILE_SEQ, EDU_SEQ, FILE_ORG, FILE_RENAME, FILE_TYPE, FILE_SIZE ,FILE_SECTION
			)VALUES(
				#{fileSeq}, #{eduSeq}, #{fileOrg}, #{fileRename}, #{fileType}, #{fileSize} , #{fileSection} 
			)
	</insert>
	
	<select id="selectAttachList" resultMap="lectureAttachMap">
		SELECT * FROM t_lecture_attach WHERE EDU_SEQ = #{eduSeq} AND FILE_SECTION=#{fileSection} 
	</select>
	
	<select id="getAttach" parameterType="Integer" resultMap="lectureAttachMap">
		SELECT * FROM t_lecture_attach WHERE FILE_SEQ = #{fileSeq} 
	</select>
	
	<delete id="deleteAttach" parameterType="Integer">
		DELETE FROM t_lecture_attach WHERE FILE_SEQ = #{fileSeq} 
	</delete>
	<select id="selectAttachCnt" resultType="int">
		/** 교육자료 존재하는지 체크, 교육자료 다운로드 버튼 온오프 용도 */
		SELECT count(*) FROM t_lecture_attach WHERE EDU_SEQ = #{eduSeq} AND FILE_SECTION=#{fileSection} 
	</select>
</mapper>