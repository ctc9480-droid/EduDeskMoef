<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educare.edu.bbs.service.impl.BoardAttachMapper">

	<resultMap id="map" type="BoardAttach">
		<result property="fileSeq" column="FILE_SEQ" />
		<result property="boardIdx" column="BOARD_IDX" />
		<result property="fileSection" column="FILE_SECTION" />
		<result property="fileOrg" column="FILE_ORG" />
		<result property="fileRename" column="FILE_RENAME" />
		<result property="fileType" column="FILE_TYPE" />
		<result property="fileSize" column="FILE_SIZE" />
	</resultMap>

	<insert id="insertBopardAttach">
		INSERT INTO
		t_board_attach(
		FILE_SEQ, BOARD_IDX, FILE_SECTION, FILE_ORG, FILE_RENAME, FILE_TYPE, FILE_SIZE
		)VALUES(
		#{fileSeq}, #{boardIdx}, #{fileSection}, #{fileOrg}, #{fileRename}, #{fileType},
		#{fileSize}
		)
	</insert>
	<select id="selectBoardAttachList" resultMap="map">
		SELECT * FROM t_board_attach WHERE BOARD_IDX=#{boardIdx}
	</select>
	<select id="selectBoardAttachMap" resultMap="map">
		SELECT * FROM t_board_attach WHERE FILE_SEQ=#{fileSeq}
	</select>
	<delete id="deleteBoardAttach" parameterType="Integer">
		DELETE FROM t_board_attach WHERE FILE_SEQ = #{fileSeq}
	</delete>
</mapper>