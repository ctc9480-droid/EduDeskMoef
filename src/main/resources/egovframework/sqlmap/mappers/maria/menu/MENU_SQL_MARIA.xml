<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.educare.edu.menu.service.impl.MenuMapper">
	
	<resultMap id="menuAuthMap" type="MenuAuth">
		<result property="menuId" column="MENU_ID"/>
		<result property="userId" column="USER_ID"/>
	</resultMap>
	
	<select id="selectMenuAuthByPk" parameterType="MenuAuth" resultMap="menuAuthMap">
		SELECT 
			MENU_ID, USER_ID 
		FROM 
			t_menu_auth
		WHERE
			MENU_ID = #{menuId} AND USER_ID = #{userId}
	</select>
	
	<select id="selectMenuAuthByMenuId" parameterType="String" resultMap="menuAuthMap">
		SELECT 
			MENU_ID, USER_ID 
		FROM 
			t_menu_auth
		WHERE
			MENU_ID = #{menuId}
	</select>
	
	<select id="selectMenuAuthByUserId" parameterType="String" resultMap="menuAuthMap">
		SELECT 
			MENU_ID, USER_ID 
		FROM 
			t_menu_auth
		WHERE
			USER_ID = #{userId}
	</select>
	
	<delete id="deleteMenuAuth" parameterType="String">
		DELETE FROM	t_menu_auth
		WHERE USER_ID = #{userId}
	</delete>
	
	<insert id="insertMenuAuth" parameterType="MenuAuth">
		INSERT INTO 
			t_menu_auth(
				MENU_ID, USER_ID 
			)VALUES(
				#{menuId}, #{userId}
			)
	</insert>
	
</mapper>